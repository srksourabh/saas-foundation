{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SaaS Audit Finding",
  "type": "object",
  "required": ["id","title","status","domain","severity","priority","environment","description","expected","actual","reproduction","risk","evidence","remediation","retest"],
  "properties": {
    "id": {"type":"string","pattern":"^[A-Z]+-[0-9]{3,}$"},
    "title": {"type":"string","minLength":5},
    "status": {"enum":["CONFIRMED","PROBABLE","OBSERVATION","BLOCKED","FALSE_POSITIVE","RETEST_PASS","RETEST_FAIL"]},
    "domain": {"type":"string"},
    "severity": {"enum":["Critical","High","Medium","Low","Informational"]},
    "priority": {"enum":["P0","P1","P2","P3","P4"]},
    "environment": {"type":"string"},
    "description": {"type":"string"},
    "expected": {"type":"string"},
    "actual": {"type":"string"},
    "reproduction": {"type":"array","minItems":1,"items":{"type":"string"}},
    "risk": {
      "type":"object",
      "required":["likelihood","technical_impact","business_impact","user_impact","exploitability","detectability","score","summary"],
      "properties": {
        "likelihood":{"type":"integer","minimum":1,"maximum":5},
        "technical_impact":{"type":"integer","minimum":1,"maximum":5},
        "business_impact":{"type":"integer","minimum":1,"maximum":5},
        "user_impact":{"type":"integer","minimum":1,"maximum":5},
        "exploitability":{"type":"integer","minimum":1,"maximum":5},
        "detectability":{"type":"integer","minimum":1,"maximum":5},
        "score":{"type":"integer","minimum":1,"maximum":25},
        "summary":{"type":"string"}
      }
    },
    "evidence":{"type":"array","items":{"type":"string"}},
    "remediation": {
      "type":"object",
      "required":["permanent_solution","validation","owner","effort"],
      "properties": {
        "containment":{"type":"string"},
        "workaround":{"type":"string"},
        "permanent_solution":{"type":"string"},
        "implementation_guidance":{"type":"string"},
        "validation":{"type":"string"},
        "regression_test":{"type":"string"},
        "owner":{"type":"string"},
        "effort":{"type":"string"},
        "target":{"type":"string"}
      }
    },
    "retest": {
      "type":"object",
      "required":["status"],
      "properties": {
        "status":{"enum":["NOT_RETESTED","PASS","FAIL","BLOCKED"]},
        "date":{"type":"string"},
        "evidence":{"type":"array","items":{"type":"string"}},
        "residual_risk":{"type":"string"}
      }
    }
  }
}
